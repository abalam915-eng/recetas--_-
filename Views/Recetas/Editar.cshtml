@model RecetasApp.Models.Receta
@{
    ViewData["Title"] = "Editar Receta";
}
<h2>Editar Receta (Borrador)</h2>
<hr />
<form asp-action="Editar" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="UsuarioId" />
    <input type="hidden" asp-for="Estatus" />
    <input type="hidden" asp-for="FechaCreacion" />
    <input type="hidden" asp-for="Imagen" />
    
    <div class="mb-3">
        <label asp-for="Titulo" class="form-label"></label>
        <input asp-for="Titulo" class="form-control" required />
    </div>
    <div class="mb-3">
        <label asp-for="Ingredientes" class="form-label"></label>
        <textarea asp-for="Ingredientes" class="form-control" rows="5" required></textarea>
    </div>
    <div class="mb-3">
        <label asp-for="Pasos" class="form-label"></label>
        <textarea asp-for="Pasos" class="form-control" rows="5" required></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Imagen de la Receta (Reemplazar)</label>
        @if(!string.IsNullOrEmpty(Model.Imagen))
        {
            <div class="mb-2">
                <img src="@Model.Imagen" alt="Imagen actual" class="img-thumbnail" style="max-height: 150px" />
            </div>
        }
        <input type="file" name="imagenArchivo" class="form-control" accept="image/*" />
    </div>
    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
    <a asp-action="MisRecetas" class="btn btn-secondary">Cancelar</a>
</form>
