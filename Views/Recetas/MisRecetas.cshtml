@{
    ViewData["Title"] = "Mis Recetas";
    var borradores = ViewBag.Borradores as IEnumerable<RecetasApp.Models.Receta>;
    var publicadas = ViewBag.Publicadas as IEnumerable<RecetasApp.Models.Receta>;
}

<h1>Mis Recetas</h1>

<div class="mb-4">
    <a asp-action="Crear" class="btn btn-primary">Crear Nueva Receta</a>
</div>

<h3>En Borrador</h3>
<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Título</th>
            <th>Fecha Creación</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if(borradores != null && borradores.Any())
        {
            foreach(var item in borradores)
            {
                <tr>
                    <td>@item.Titulo</td>
                    <td>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                        <form asp-action="Publicar" asp-route-id="@item.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-success">Publicar Copia</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="3" class="text-center">No hay borradores.</td></tr>
        }
    </tbody>
</table>

<h3 class="mt-5">Publicadas</h3>
<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Título</th>
            <th>Fecha Publicación</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @if(publicadas != null && publicadas.Any())
        {
            foreach(var item in publicadas)
            {
                <tr>
                    <td>@item.Titulo</td>
                    <td>@item.FechaPublicacion?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <span class="badge bg-success">Publicada</span>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="3" class="text-center">No has publicado recetas aún.</td></tr>
        }
    </tbody>
</table>
